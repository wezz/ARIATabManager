{
  "name": "@wezz/ariatabmanager",
  "version": "1.0.7",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ariatabmanager.js",
      "require": "./dist/ariatabmanager.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepare": "npm run build",
    "pack": "npm run build",
    "trypublish": "npm publish --access public || true",
    "eslint": "eslint --ext .ts",
    "prettier": "prettier --write \"**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wezz/ARIATabManager.git"
  },
  "author": "Wezz Balk <github@wezz.se> (https://github.com/wezz)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wezz/ARIATabManager/issues"
  },
  "homepage": "https://github.com/wezz/ARIATabManager",
  "keywords": [
    "wai-aria",
    "aria",
    "accessibility"
  ],
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.3"
  },
  "dependencies": {
    "@wezz/ariamanager": "~1.0.9"
  }
}
