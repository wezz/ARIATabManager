{
  "name": "@wezz/ariatabmanager",
  "version": "1.2.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.umd.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node ./scripts/build-cts.mjs",
    "test": "vitest run",
    "check:exports": "publint && attw --pack --ignore-rules false-export-default",
    "prepare": "npm run build",
    "pack": "npm run build",
    "prepublishOnly": "npm run build && publint",
    "trypublish": "npm publish --access public || true",
    "eslint": "eslint --ext .ts",
    "prettier": "prettier --write \"**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wezz/ARIATabManager.git"
  },
  "author": "Wezz Balk <github@wezz.se> (https://github.com/wezz)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wezz/ARIATabManager/issues"
  },
  "homepage": "https://github.com/wezz/ARIATabManager",
  "keywords": [
    "wai-aria",
    "aria",
    "accessibility"
  ],
  "peerDependencies": {
    "@wezz/ariamanager": "^1.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@types/node": "^22.14.1",
    "@wezz/ariamanager": "^1.1.2",
    "jsdom": "^26.0.0",
    "publint": "^0.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.2.0"
  }
}
